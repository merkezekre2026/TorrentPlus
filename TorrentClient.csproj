<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <ApplicationIcon></ApplicationIcon>
    <AssemblyName>TorrentClient</AssemblyName>
    <RootNamespace>TorrentClient</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <!-- Torrent Motoru: MonoTorrent (Açık kaynak, .NET native) -->
    <PackageReference Include="MonoTorrent" Version="3.0.0" />
    
    <!-- MVVM Framework: CommunityToolkit.Mvvm (Hafif ve modern) -->
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.2.2" />
    
    <!-- UI İyileştirme: Modern WPF kontrolleri için -->
    <PackageReference Include="ModernWpfUI" Version="0.9.6" />
    
    <!-- Loglama: Serilog -->
    <PackageReference Include="Serilog" Version="3.1.1" />
    <PackageReference Include="Serilog.Sinks.File" Version="5.0.0" />
    <PackageReference Include="Serilog.Sinks.Debug" Version="2.0.0" />
  </ItemGroup>

</Project>
