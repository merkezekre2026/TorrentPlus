<Window x:Class="TorrentClient.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:models="clr-namespace:TorrentClient.Models"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" 
        Height="700" 
        Width="1200"
        MinHeight="500"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#FAFAFA">

    <Window.Resources>
        <!-- Durum renkleri -->
        <Style x:Key="DownloadingStateStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1976D2"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        
        <Style x:Key="SeedingStateStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#388E3C"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        
        <Style x:Key="PausedStateStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F57C00"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        
        <Style x:Key="ErrorStateStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D32F2F"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Progress Bar Style -->
        <Style x:Key="TorrentProgressBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="18"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="Background" Value="#E0E0E0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TOOLBAR (Üst Kısım) -->
        <Border Grid.Row="0" Background="#FFFFFF" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="10,8">
                <!-- Ekle Butonları -->
                <Button Content="➕ Magnet Ekle" 
                        Command="{Binding AddMagnetLinkCommand}"
                        Style="{StaticResource ToolbarButtonStyle}"
                        ToolTip="Magnet linki ile torrent ekle"/>
                
                <Button Content="📁 Dosya Ekle" 
                        Command="{Binding AddTorrentFileCommand}"
                        Style="{StaticResource ToolbarButtonStyle}"
                        ToolTip=".torrent dosyası seç"/>

                <Separator Width="1" Background="#E0E0E0" Margin="10,0"/>

                <!-- Kontrol Butonları -->
                <Button Content="▶ Başlat" 
                        Command="{Binding StartTorrentCommand}"
                        Style="{StaticResource ToolbarButtonStyle}"
                        ToolTip="Seçili torrent'i başlat"/>
                
                <Button Content="⏸ Duraklat" 
                        Command="{Binding PauseTorrentCommand}"
                        Style="{StaticResource ToolbarButtonStyle}"
                        ToolTip="Seçili torrent'i duraklat"/>
                
                <Button Content="⏹ Durdur" 
                        Command="{Binding StopTorrentCommand}"
                        Style="{StaticResource ToolbarButtonStyle}"
                        ToolTip="Seçili torrent'i durdur"/>

                <Separator Width="1" Background="#E0E0E0" Margin="10,0"/>

                <Button Content="🗑 Kaldır" 
                        Command="{Binding RemoveTorrentCommand}"
                        Style="{StaticResource ToolbarButtonStyle}"
                        ToolTip="Seçili torrent'i listeden kaldır"/>
            </StackPanel>
        </Border>

        <!-- TORRENT LİSTESİ (Orta Kısım - Grid) -->
        <Grid Grid.Row="1" Margin="10">
            <DataGrid ItemsSource="{Binding Torrents}"
                      SelectedItem="{Binding SelectedTorrent}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="0"
                      Background="White"
                      AlternatingRowBackground="#F5F5F5"
                      RowHeight="45">
                
                <DataGrid.Columns>
                    <!-- Ad -->
                    <DataGridTemplateColumn Header="Ad" Width="250">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" 
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap"
                                               MaxWidth="240"/>
                                    <TextBlock Text="{Binding Hash, StringFormat='Hash: {0}'}" 
                                               FontSize="10"
                                               Foreground="#757575"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- İlerleme -->
                    <DataGridTemplateColumn Header="İlerleme" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel VerticalAlignment="Center">
                                    <ProgressBar Value="{Binding Progress}" 
                                                 Style="{StaticResource TorrentProgressBar}"
                                                 Margin="0,2"/>
                                    <TextBlock Text="{Binding ProgressFormatted}" 
                                               FontSize="11"
                                               HorizontalAlignment="Center"
                                               Foreground="#424242"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- İndirme Hızı -->
                    <DataGridTextColumn Header="↓ Hız" 
                                        Binding="{Binding DownloadSpeedFormatted}"
                                        Width="80"/>

                    <!-- Yükleme Hızı -->
                    <DataGridTextColumn Header="↑ Hız" 
                                        Binding="{Binding UploadSpeedFormatted}"
                                        Width="80"/>

                    <!-- Boyut -->
                    <DataGridTextColumn Header="Boyut" 
                                        Binding="{Binding TotalSizeFormatted}"
                                        Width="80"/>

                    <!-- İndirilen -->
                    <DataGridTextColumn Header="İndirilen" 
                                        Binding="{Binding DownloadedSizeFormatted}"
                                        Width="90"/>

                    <!-- Peers/Seeds -->
                    <DataGridTemplateColumn Header="Peers/Seeds" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock>
                                    <Run Text="{Binding Peers}" Foreground="#1976D2"/>
                                    <Run Text="/"/>
                                    <Run Text="{Binding Seeds}" Foreground="#388E3C"/>
                                </TextBlock>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <!-- Durum -->
                    <DataGridTemplateColumn Header="Durum" Width="100">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="3" Padding="8,4"
                                        Background="{Binding State, Converter={StaticResource StateToBackgroundConverter}, FallbackValue=#E3F2FD}">
                                    <TextBlock Text="{Binding StateFormatted}" 
                                               FontWeight="SemiBold"
                                               FontSize="12"
                                               Foreground="{Binding State, Converter={StaticResource StateToForegroundConverter}, FallbackValue=#1976D2}"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- DETAY PANELİ (Alt Kısım - Seçili Torrent Detayları) -->
        <Border Grid.Row="2" Margin="10,0,10,10" 
                Background="White" 
                BorderBrush="#E0E0E0" 
                BorderThickness="1"
                CornerRadius="4">
            <Grid Margin="15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sol Panel - Genel Bilgiler -->
                <StackPanel Grid.Column="0">
                    <TextBlock Text="GENEL BİLGİLER" 
                               FontWeight="Bold" 
                               FontSize="14"
                               Margin="0,0,0,10"
                               Foreground="#424242"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Ad:" Foreground="#757575"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedTorrent.Name, FallbackValue='-'}" FontWeight="SemiBold"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Durum:" Foreground="#757575"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedTorrent.StateFormatted, FallbackValue='-'}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="İlerleme:" Foreground="#757575"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedTorrent.ProgressFormatted, FallbackValue='-'}"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Eklenme:" Foreground="#757575"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedTorrent.AddedDate, StringFormat={}{0:dd.MM.yyyy HH:mm}, FallbackValue='-'}"/>
                    </Grid>
                </StackPanel>

                <!-- Orta Panel - Hız Bilgileri -->
                <StackPanel Grid.Column="1">
                    <TextBlock Text="HIZ BİLGİLERİ" 
                               FontWeight="Bold" 
                               FontSize="14"
                               Margin="0,0,0,10"
                               Foreground="#424242"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="↓ İndirme:" Foreground="#757575"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedTorrent.DownloadSpeedFormatted, FallbackValue='-'}" 
                                   Foreground="#1976D2" FontWeight="SemiBold"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="↑ Yükleme:" Foreground="#757575"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedTorrent.UploadSpeedFormatted, FallbackValue='-'}" 
                                   Foreground="#388E3C" FontWeight="SemiBold"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Toplam:" Foreground="#757575"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" FontWeight="SemiBold">
                            <Run Text="{Binding TotalDownloadSpeed, Converter={StaticResource SpeedConverter}, FallbackValue='0 B/s'}" Foreground="#1976D2"/>
                            <Run Text=" / "/>
                            <Run Text="{Binding TotalUploadSpeed, Converter={StaticResource SpeedConverter}, FallbackValue='0 B/s'}" Foreground="#388E3C"/>
                        </TextBlock>
                    </Grid>
                </StackPanel>

                <!-- Sağ Panel - Bağlantılar -->
                <StackPanel Grid.Column="2">
                    <TextBlock Text="BAĞLANTILAR" 
                               FontWeight="Bold" 
                               FontSize="14"
                               Margin="0,0,0,10"
                               Foreground="#424242"/>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition/>
                            <RowDefinition/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Peers:" Foreground="#757575"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedTorrent.Peers, FallbackValue='0'}" 
                                   Foreground="#1976D2" FontWeight="SemiBold"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Seeds:" Foreground="#757575"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedTorrent.Seeds, FallbackValue='0'}" 
                                   Foreground="#388E3C" FontWeight="SemiBold"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Aktif:" Foreground="#757575"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding ActiveTorrentCount}" FontWeight="SemiBold"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Border>

        <!-- STATUS BAR (En Alt) -->
        <Border Grid.Row="3" Background="#37474F" Padding="15,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           Text="{Binding StatusBarMessage}" 
                           Foreground="White"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Foreground="#B0BEC5" VerticalAlignment="Center">
                        <Run Text="Aktif Torrent: "/>
                        <Run Text="{Binding ActiveTorrentCount}" FontWeight="Bold" Foreground="White"/>
                    </TextBlock>
                    <TextBlock Foreground="#B0BEC5" Margin="20,0,0,0" VerticalAlignment="Center">
                        <Run Text="↓ "/>
                        <Run Text="{Binding TotalDownloadSpeed, Converter={StaticResource SpeedConverter}, FallbackValue='0 B/s'}" FontWeight="Bold" Foreground="#4FC3F7"/>
                        <Run Text="  ↑ "/>
                        <Run Text="{Binding TotalUploadSpeed, Converter={StaticResource SpeedConverter}, FallbackValue='0 B/s'}" FontWeight="Bold" Foreground="#81C784"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
